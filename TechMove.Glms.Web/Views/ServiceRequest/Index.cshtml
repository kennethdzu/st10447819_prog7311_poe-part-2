@model IEnumerable<TechMove.Glms.Web.Models.ServiceRequest>
@{
    ViewData["Title"] = "Service Requests";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Service Requests</h2>
    <a asp-action="Create" class="btn btn-primary">Create Service Request</a>
</div>

<table class="table table-hover table-bordered shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Contract ID</th>
            <th>Client</th>
            <th>Description</th>
            <th>Expected Cost (ZAR)</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.ContractId</td>
                <td>@item.Contract?.Client?.Name</td>
                <td>@item.Description</td>
                <td>R @item.Cost.ToString("N2")</td>
                <td><span class="badge bg-info text-dark">@item.Status</span></td>
            </tr>
        }
    </tbody>
</table>
